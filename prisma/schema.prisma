generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

enum TipoDocumento {
  DNI
  RUC
  CE
  PASAPORTE
}

enum TipoComprobante {
  BOLETA
  FACTURA
  NOTA_CREDITO
  NOTA_DEBITO
  TICKET
  COTIZACION
  ORDEN_COMPRA
  GUIA_REMISION
}

enum TipoMovimiento {
  INGRESO
  EGRESO
}

enum OrigenMovimiento {
  COMPRA
  VENTA
  AJUSTE
  TRASPASO
}

enum EstadoSuscripcion {
  ACTIVA
  VENCIDA
  CANCELADA
  PRUEBA
}

enum EstadoSunat {
  BORRADOR
  ENVIADO
  ACEPTADO
  RECHAZADO
  ANULADO
}

enum EstadoCotizacion {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum EstadoCompra {
  REGISTRADO
  RECEPCIONADO
  ANULADO
}

enum EstadoTurnoCaja {
  ABIERTO
  CERRADO
}

enum EstadoTransferencia {
  PENDIENTE
  EN_TRANSITO
  COMPLETADA
  CANCELADA
}

// -----------------------------------------------------------------------------
// NÚCLEO SAAS (Múltiples Empresas)
// -----------------------------------------------------------------------------

model PlanSaaS {
  id                 String        @id @default(uuid())
  nombre             String        @unique // Básico, Profesional, Empresarial
  precioMensual      Decimal       @db.Decimal(10, 2)
  precioAnual        Decimal       @db.Decimal(10, 2)
  limiteUsuarios     Int
  limiteSucursales   Int
  limiteComprobantes Int
  estado             Boolean       @default(true)
  suscripciones      Suscripcion[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Suscripcion {
  id        String   @id @default(uuid())
  empresaId String   @unique
  empresa   Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  planId    String
  plan      PlanSaaS @relation(fields: [planId], references: [id])

  fechaInicio      DateTime          @default(now())
  fechaVencimiento DateTime
  estado           EstadoSuscripcion @default(PRUEBA)

  culqiCustomerId     String?
  culqiSubscriptionId String?
  renovacionAuto      Boolean @default(true)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Empresa {
  id              String  @id @default(uuid())
  subdominio      String  @unique
  ruc             String  @unique @db.VarChar(11)
  razonSocial     String
  nombreComercial String?
  direccion       String?
  ubigeo          String? @db.VarChar(6)
  emailContacto   String?
  telefono        String?
  logoUrl         String?

  nubefactToken String?
  nubefactUrl   String?
  configuracion Json?

  suscripcion Suscripcion?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  usuarios        Usuario[]
  sucursales      Sucursal[]
  roles           Rol[]
  productos       Producto[]
  categorias      Categoria[]
  marcas          Marca[]
  clientes        Cliente[]
  proveedores     Proveedor[]
  ventas          Venta[]
  compras         Compra[]
  cotizaciones    Cotizacion[]
  auditorias      Auditoria[]
  kardex          Kardex[]
  turnosCaja      TurnoCaja[]
  cajaMovimientos CajaMovimiento[]
  transferencias  TransferenciaInventario[]
}

model Sucursal {
  id        String  @id @default(uuid())
  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  nombre      String
  direccion   String?
  ubigeo      String? @db.VarChar(6)
  codigoSunat String? @db.VarChar(4) // Ej: "0000"
  telefono    String?
  estado      Boolean @default(true)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  seriesSunat  SerieSunat[]
  usuarios     Usuario[]
  inventarios  InventarioSucursal[]
  kardex       Kardex[]
  cajas        Caja[]
  ventas       Venta[]
  compras      Compra[]
  cotizaciones Cotizacion[]

  transferenciasOrigen  TransferenciaInventario[] @relation("SucursalOrigen")
  transferenciasDestino TransferenciaInventario[] @relation("SucursalDestino")

  @@index([empresaId])
}

// -----------------------------------------------------------------------------
// CONTROL DE ACCESOS (RBAC AVANZADO)
// -----------------------------------------------------------------------------

model Permiso {
  id          String       @id @default(uuid())
  codigo      String       @unique // ej: "VENTAS_CREAR", "INVENTARIO_VER"
  descripcion String?
  roles       RolPermiso[]
}

model Rol {
  id          String  @id @default(uuid())
  empresaId   String
  empresa     Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  nombre      String // Ej: ADMIN, VENDEDOR, ALMACEN
  descripcion String?

  permisos RolPermiso[]
  usuarios Usuario[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([empresaId, nombre])
}

model RolPermiso {
  rolId     String
  permisoId String
  rol       Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permiso   Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@id([rolId, permisoId])
}

model Usuario {
  id         String    @id @default(uuid())
  empresaId  String
  empresa    Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  sucursalId String?
  sucursal   Sucursal? @relation(fields: [sucursalId], references: [id])
  rolId      String
  rol        Rol       @relation(fields: [rolId], references: [id])

  nombre       String
  email        String
  passwordHash String
  avatarUrl    String?
  estado       Boolean @default(true)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  ventas                  Venta[]
  compras                 Compra[]
  movimientosCaja         CajaMovimiento[]
  auditorias              Auditoria[]
  historialPrecios        HistorialPrecioProducto[]
  transferenciasEnviadas  TransferenciaInventario[] @relation("UsuarioEnvio")
  transferenciasRecibidas TransferenciaInventario[] @relation("UsuarioRecepcion")

  @@unique([empresaId, email])
}

// -----------------------------------------------------------------------------
// FACTURACIÓN ELECTRÓNICA (NUMERACIÓN SUNAT)
// -----------------------------------------------------------------------------

model SerieSunat {
  id         String   @id @default(uuid())
  sucursalId String
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)

  tipoComprobante TipoComprobante // BOLETA, FACTURA, NOTA_CREDITO, NOTA_DEBITO
  serie           String          @db.VarChar(4) // Ej: F001, B001, FC01
  correlativo     Int             @default(1)

  estado    Boolean   @default(true)
  deletedAt DateTime?

  @@unique([sucursalId, tipoComprobante, serie])
}

// -----------------------------------------------------------------------------
// CATÁLOGO E INVENTARIO POR SUCURSAL
// -----------------------------------------------------------------------------

model Categoria {
  id        String     @id @default(uuid())
  empresaId String
  empresa   Empresa    @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  nombre    String
  productos Producto[]
  deletedAt DateTime?

  @@index([empresaId])
}

model Marca {
  id        String     @id @default(uuid())
  empresaId String
  empresa   Empresa    @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  nombre    String
  productos Producto[]
  deletedAt DateTime?

  @@index([empresaId])
}

model Producto {
  id        String  @id @default(uuid())
  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  codigo       String?
  codigoBarras String?
  nombre       String
  descripcion  String?

  precioCompra Decimal @db.Decimal(10, 2)
  precioVenta  Decimal @db.Decimal(10, 2)
  afectoIGV    Boolean @default(true)

  categoriaId String?
  categoria   Categoria? @relation(fields: [categoriaId], references: [id])
  marcaId     String?
  marca       Marca?     @relation(fields: [marcaId], references: [id])

  stockMinimo Int     @default(0)
  imageUrl    String?
  estado      Boolean @default(true)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  inventarios      InventarioSucursal[]
  historialPrecios HistorialPrecioProducto[]
  kardex           Kardex[]
  ventaDetalles    VentaDetalle[]
  compraDetalles   CompraDetalle[]
  cotizacionDet    CotizacionDetalle[]
  transferenciaDet TransferenciaDetalle[]

  @@index([empresaId, codigo])
  @@index([empresaId, nombre])
}

model HistorialPrecioProducto {
  id         String   @id @default(uuid())
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  usuarioId  String
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])

  precioAnterior Decimal  @db.Decimal(10, 2)
  precioNuevo    Decimal  @db.Decimal(10, 2)
  fecha          DateTime @default(now())

  @@index([productoId])
}

model InventarioSucursal {
  id         String   @id @default(uuid())
  sucursalId String
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  stockActual      Int     @default(0)
  ubicacionPasillo String?

  updatedAt DateTime @updatedAt

  @@unique([sucursalId, productoId])
  @@index([sucursalId])
}

model Kardex {
  id         String   @id @default(uuid())
  empresaId  String
  empresa    Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  sucursalId String
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  tipoMovimiento TipoMovimiento
  origen         OrigenMovimiento
  cantidad       Int
  stockSaldo     Int // Stock resultante en ESA sucursal
  costoUnitario  Decimal?         @db.Decimal(10, 2)
  referenciaId   String? // ID de la Venta, Compra o Transferencia
  detalle        String?

  fecha DateTime @default(now())

  @@index([empresaId, fecha])
  @@index([sucursalId, productoId])
}

// -----------------------------------------------------------------------------
// TRANSFERENCIAS DE INVENTARIO
// -----------------------------------------------------------------------------

model TransferenciaInventario {
  id        String  @id @default(uuid())
  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  sucursalOrigenId  String
  sucursalOrigen    Sucursal @relation("SucursalOrigen", fields: [sucursalOrigenId], references: [id])
  sucursalDestinoId String
  sucursalDestino   Sucursal @relation("SucursalDestino", fields: [sucursalDestinoId], references: [id])

  estado EstadoTransferencia @default(PENDIENTE)

  fechaEnvio     DateTime  @default(now())
  fechaRecepcion DateTime?

  usuarioEnvioId     String
  usuarioEnvio       Usuario  @relation("UsuarioEnvio", fields: [usuarioEnvioId], references: [id])
  usuarioRecepcionId String?
  usuarioRecepcion   Usuario? @relation("UsuarioRecepcion", fields: [usuarioRecepcionId], references: [id])

  observaciones String?

  detalles TransferenciaDetalle[]

  @@index([empresaId, fechaEnvio])
}

model TransferenciaDetalle {
  id              String                  @id @default(uuid())
  transferenciaId String
  transferencia   TransferenciaInventario @relation(fields: [transferenciaId], references: [id], onDelete: Cascade)
  productoId      String
  producto        Producto                @relation(fields: [productoId], references: [id])

  cantidad Int
}

// -----------------------------------------------------------------------------
// CRM: CLIENTES Y PROVEEDORES
// -----------------------------------------------------------------------------

model Cliente {
  id        String  @id @default(uuid())
  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  tipoDocumento   TipoDocumento
  numeroDocumento String
  nombre          String
  direccion       String?
  email           String?
  telefono        String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  ventas       Venta[]
  cotizaciones Cotizacion[]

  @@unique([empresaId, tipoDocumento, numeroDocumento])
  @@index([empresaId, numeroDocumento])
  @@index([empresaId, nombre])
}

model Proveedor {
  id        String  @id @default(uuid())
  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  ruc         String  @db.VarChar(11)
  razonSocial String
  direccion   String?
  email       String?
  telefono    String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())

  compras Compra[]

  @@unique([empresaId, ruc])
}

// -----------------------------------------------------------------------------
// VENTAS Y COMPRAS (TRANSACCIONAL)
// -----------------------------------------------------------------------------

model Cotizacion {
  id         String   @id @default(uuid())
  empresaId  String
  empresa    Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  sucursalId String
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id])
  clienteId  String?
  cliente    Cliente? @relation(fields: [clienteId], references: [id])

  numero String
  total  Decimal          @db.Decimal(12, 2)
  estado EstadoCotizacion @default(PENDIENTE)

  deletedAt DateTime?
  createdAt DateTime  @default(now())

  detalles CotizacionDetalle[]

  @@index([empresaId, createdAt])
}

model CotizacionDetalle {
  id             String     @id @default(uuid())
  cotizacionId   String
  cotizacion     Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  productoId     String
  producto       Producto   @relation(fields: [productoId], references: [id])
  cantidad       Int
  precioUnitario Decimal    @db.Decimal(10, 2)
  total          Decimal    @db.Decimal(12, 2)
}

model Venta {
  id         String   @id @default(uuid())
  empresaId  String
  empresa    Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  sucursalId String
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id])
  usuarioId  String
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  clienteId  String?
  cliente    Cliente? @relation(fields: [clienteId], references: [id])

  tipoComprobante TipoComprobante
  serie           String          @db.VarChar(4)
  correlativo     Int

  fechaEmision DateTime @default(now())
  moneda       String   @default("PEN")

  subtotal  Decimal @db.Decimal(12, 2)
  igv       Decimal @db.Decimal(12, 2)
  descuento Decimal @default(0.00) @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)

  // SUNAT
  estadoSunat EstadoSunat @default(BORRADOR)
  nubefactId  String?
  xmlUrl      String?
  cdrUrl      String?
  pdfUrl      String?

  metodoPago String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())

  detalles VentaDetalle[]

  @@unique([empresaId, tipoComprobante, serie, correlativo])
  @@index([empresaId, fechaEmision])
}

model VentaDetalle {
  id         String   @id @default(uuid())
  ventaId    String
  venta      Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id])

  cantidad       Int
  precioUnitario Decimal @db.Decimal(10, 2)
  total          Decimal @db.Decimal(12, 2)
}

model Compra {
  id          String    @id @default(uuid())
  empresaId   String
  empresa     Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  sucursalId  String
  sucursal    Sucursal  @relation(fields: [sucursalId], references: [id])
  usuarioId   String
  usuario     Usuario   @relation(fields: [usuarioId], references: [id])
  proveedorId String
  proveedor   Proveedor @relation(fields: [proveedorId], references: [id])

  tipoComprobante TipoComprobante
  serie           String
  correlativo     String
  total           Decimal         @db.Decimal(12, 2)

  estado EstadoCompra @default(REGISTRADO)

  deletedAt DateTime?
  createdAt DateTime  @default(now())

  detalles CompraDetalle[]

  @@unique([empresaId, serie, correlativo])
  @@index([empresaId, createdAt])
}

model CompraDetalle {
  id             String   @id @default(uuid())
  compraId       String
  compra         Compra   @relation(fields: [compraId], references: [id], onDelete: Cascade)
  productoId     String
  producto       Producto @relation(fields: [productoId], references: [id])
  cantidad       Int
  precioUnitario Decimal  @db.Decimal(10, 2)
  total          Decimal  @db.Decimal(12, 2)
}

// -----------------------------------------------------------------------------
// CAJAS MÚLTIPLES POR SUCURSAL
// -----------------------------------------------------------------------------

model Caja {
  id         String   @id @default(uuid())
  sucursalId String
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)

  nombre String // Ej: Caja 1, Caja Principal
  estado Boolean @default(true)

  deletedAt DateTime?
  createdAt DateTime  @default(now())

  turnos TurnoCaja[]
}

model TurnoCaja {
  id        String  @id @default(uuid())
  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cajaId    String
  caja      Caja    @relation(fields: [cajaId], references: [id], onDelete: Cascade)
  usuarioId String

  fechaApertura DateTime  @default(now())
  fechaCierre   DateTime?

  montoInicial Decimal  @db.Decimal(10, 2)
  montoFinal   Decimal? @db.Decimal(10, 2)
  diferencia   Decimal? @db.Decimal(10, 2)

  estado EstadoTurnoCaja @default(ABIERTO)

  movimientos CajaMovimiento[]

  @@index([empresaId, fechaApertura])
}

model CajaMovimiento {
  id          String    @id @default(uuid())
  empresaId   String
  empresa     Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  turnoCajaId String
  turnoCaja   TurnoCaja @relation(fields: [turnoCajaId], references: [id], onDelete: Cascade)
  usuarioId   String
  usuario     Usuario   @relation(fields: [usuarioId], references: [id])

  tipoMovimiento TipoMovimiento
  monto          Decimal        @db.Decimal(10, 2)
  concepto       String
  metodoPago     String
  referenciaId   String?

  fecha DateTime @default(now())

  @@index([empresaId, fecha])
}

// -----------------------------------------------------------------------------
// AUDITORÍA Y LOGS
// -----------------------------------------------------------------------------

model Auditoria {
  id        String   @id @default(uuid())
  empresaId String
  empresa   Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuarioId String?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  accion        String
  tablaAfectada String
  registroId    String?
  detalles      Json?
  ip            String?

  fecha DateTime @default(now())

  @@index([empresaId, fecha])
}
